VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Anthropic API key for AI text cleanup in the query form
# The cleanup tries 3 methods in order:
# 1. Supabase Edge Function (if deployed) — set ANTHROPIC_API_KEY in Edge Function secrets
# 2. Vite dev proxy (local dev only) — uses this key via /api/anthropic proxy
# 3. Local cleanup fallback (no AI, fixes common spelling + capitalization)
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key
